{
  "name": "flytrapds",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "live": "pnpm --filter @flytrap/docs live",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "tokens": "pnpm -F @flytrap/tokens build",
    "tokens:contract": "python3 scripts/token_contract.py packages/tokens/src/flytrap.tokens.json",
    "apca": "python3 scripts/apca_gate.py packages/tokens/src/flytrap.tokens.json"
  },
  "devDependencies": {
    "turbo": "^2.10.4"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
