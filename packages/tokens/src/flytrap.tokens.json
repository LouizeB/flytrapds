  "color": {
    "surface": {
      "default": {
        "$type": "color",
        "$value": "{primitive.neutral.50}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.neutral.900}"
          }
        }
      }
    },
    "action": {
      "primary-bg": {
        "$value": "{primitive.magenta.500}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.magenta.500}"
          }
        }
      },
      "secondary-bg": {
        "$value": "{primitive.acid.300}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.acid.300}"
          }
        }
      }
    },
    "text": {
      "default": {
        "$value": "{primitive.neutral.900}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.neutral.100}"
          },
          "apca": {
            "role": "body",
            "on": "color.surface.default"
          }
        }
      },
      "subtle": {
        "$value": "{primitive.neutral.600}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.neutral.300}"
          },
          "apca": {
            "role": "ui",
            "on": "color.surface.default"
          }
        }
      },
      "link": {
        "$value": "{primitive.magenta.600}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.magenta.300}"
          },
          "apca": {
            "role": "ui",
            "on": "color.surface.default"
          }
        }
      },
      "on-primary": {
        "$value": "#FFFFFF",
        "$extensions": {
          "modes": {
            "dark": "#FFFFFF"
          },
          "apca": {
            "role": "ui",
            "on": "color.action.primary-bg"
          }
        }
      },
      "on-secondary": {
        "$value": "{primitive.neutral.900}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.neutral.950}"
          },
          "apca": {
            "role": "ui",
            "on": "color.action.secondary-bg"
          }
        }
      }
    },
    "feedback": {
