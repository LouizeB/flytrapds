{
  "$extensions": {
    "flytrap": {
      "brand": "flytrap",
      "modes": ["light", "dark", "vibrant"]
    }
  },
  "primitive": {
    "magenta": {
      "50": {
        "$type": "color",
        "$value": "#FFFFFF"
      },
      "100": {
        "$value": "#FFEEF6"
      },
      "200": {
        "$value": "#FFD0E2"
      },
      "300": {
        "$value": "#FFA7C7"
      },
      "400": {
        "$value": "#FF64A4"
      },
      "500": {
        "$value": "#F10081"
      },
      "600": {
        "$value": "#CF006A"
      },
      "700": {
        "$value": "#AD0057"
      },
      "800": {
        "$value": "#870042"
      },
      "900": {
        "$value": "#63002E"
      },
      "950": {
        "$value": "#45001C"
      }
    },
    "acid": {
      "50": {
        "$type": "color",
        "$value": "#B9FFA6"
      },
      "100": {
        "$value": "#83FF62"
      },
      "200": {
        "$value": "#52F617"
      },
      "300": {
        "$value": "#32DC00"
      },
      "400": {
        "$value": "#00B800"
      },
      "500": {
        "$value": "#009200"
      },
      "600": {
        "$value": "#007800"
      },
      "700": {
        "$value": "#006100"
      },
      "800": {
        "$value": "#004900"
      },
      "900": {
        "$value": "#003205"
      },
      "950": {
        "$value": "#001F03"
      }
    },
    "neutral": {
      "50": {
        "$type": "color",
        "$value": "#FFF4F5"
      },
      "100": {
        "$value": "#F4E8EA"
      },
      "200": {
        "$value": "#E0D4D6"
      },
      "300": {
        "$value": "#C6BCBD"
      },
      "400": {
        "$value": "#A59B9D"
      },
      "500": {
        "$value": "#837A7B"
      },
      "600": {
        "$value": "#6C6465"
      },
      "700": {
        "$value": "#585052"
      },
      "800": {
        "$value": "#433C3D"
      },
      "900": {
        "$value": "#2F282A"
      },
      "950": {
        "$value": "#1E1819"
      }
    },
    "success": {
      "50": {
        "$type": "color",
        "$value": "#B2FFC9"
      },
      "100": {
        "$value": "#73FFA7"
      },
      "200": {
        "$value": "#4DF390"
      },
      "300": {
        "$value": "#26D97A"
      },
      "400": {
        "$value": "#00B75C"
      },
      "500": {
        "$value": "#009143"
      },
      "600": {
        "$value": "#007736"
      },
      "700": {
        "$value": "#00602A"
      },
      "800": {
        "$value": "#00481E"
      },
      "900": {
        "$value": "#003113"
      },
      "950": {
        "$value": "#001E0A"
      }
    },
    "warning": {
      "50": {
        "$type": "color",
        "$value": "#FFF6D9"
      },
      "100": {
        "$value": "#FFE8B9"
      },
      "200": {
        "$value": "#FFCE7C"
      },
      "300": {
        "$value": "#FFAA00"
      },
      "400": {
        "$value": "#E38A00"
      },
      "500": {
        "$value": "#B86A00"
      },
      "600": {
        "$value": "#9C5400"
      },
      "700": {
        "$value": "#844000"
      },
      "800": {
        "$value": "#692C00"
      },
      "900": {
        "$value": "#4D1B00"
      },
      "950": {
        "$value": "#311100"
      }
    },
    "error": {
      "50": {
        "$type": "color",
        "$value": "#FFFAF7"
      },
      "100": {
        "$value": "#FFEAE5"
      },
      "200": {
        "$value": "#FFCEC5"
      },
      "300": {
        "$value": "#FFA79A"
      },
      "400": {
        "$value": "#FF685B"
      },
      "500": {
        "$value": "#DD463D"
      },
      "600": {
        "$value": "#BE3029"
      },
      "700": {
        "$value": "#A21A18"
      },
      "800": {
        "$value": "#830006"
      },
      "900": {
        "$value": "#640000"
      },
      "950": {
        "$value": "#450000"
      }
    }
  },
  "foundation": {
    "icon": {
      "size": {
        "sm": { "$type": "dimension", "$value": "0.875rem" },
        "md": { "$type": "dimension", "$value": "1rem" },
        "lg": { "$type": "dimension", "$value": "1.25rem" }
      },
      "stroke": { "$type": "number", "$value": 1.75 }
    },
    "radius": {
      "sm": { "$type": "dimension", "$value": "0.375rem" },
      "md": { "$type": "dimension", "$value": "0.5rem" },
      "lg": { "$type": "dimension", "$value": "0.625rem" },
      "pill": { "$type": "dimension", "$value": "9999px" }
    },
    "motion": {
      "fast": { "$type": "duration", "$value": "120ms" },
      "base": { "$type": "duration", "$value": "240ms" },
      "fluid": { "$type": "duration", "$value": "480ms" },
      "ease-organic": { "$type": "cubicBezier", "$value": "cubic-bezier(.34,1.56,.64,1)" },
      "ease-liquid": { "$type": "cubicBezier", "$value": "cubic-bezier(.65,0,.35,1)" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.neutral.50}", "$extensions": { "modes": { "dark": "{primitive.neutral.900}", "vibrant": "{primitive.magenta.950}" } } },
    "foreground": { "$value": "{primitive.neutral.900}", "$extensions": { "modes": { "dark": "{primitive.neutral.100}", "vibrant": "{primitive.magenta.50}" } } },
    "card": { "$value": "{primitive.neutral.50}", "$extensions": { "modes": { "dark": "{primitive.neutral.800}", "vibrant": "{primitive.magenta.900}" } } },
    "card-foreground": { "$value": "{primitive.neutral.900}", "$extensions": { "modes": { "dark": "{primitive.neutral.100}", "vibrant": "{primitive.magenta.50}" } } },
    "popover": { "$value": "{primitive.neutral.100}", "$extensions": { "modes": { "dark": "{primitive.neutral.800}", "vibrant": "{primitive.magenta.900}" } } },
    "popover-foreground": { "$value": "{primitive.neutral.900}", "$extensions": { "modes": { "dark": "{primitive.neutral.100}", "vibrant": "{primitive.magenta.50}" } } },
    "primary": { "$value": "{primitive.magenta.500}" },
    "primary-hover": { "$value": "{primitive.magenta.600}", "$extensions": { "modes": { "dark": "{primitive.magenta.600}", "vibrant": "{primitive.magenta.600}" } } },
    "primary-disabled": { "$value": "{primitive.magenta.200}", "$extensions": { "modes": { "dark": "{primitive.magenta.800}", "vibrant": "{primitive.magenta.800}" } } },
    "primary-foreground": { "$value": "{primitive.magenta.50}" },
    "secondary": { "$value": "{primitive.acid.300}" },
    "secondary-hover": { "$value": "{primitive.acid.200}", "$extensions": { "modes": { "dark": "{primitive.acid.200}", "vibrant": "{primitive.acid.200}" } } },
    "secondary-disabled": { "$value": "{primitive.acid.100}", "$extensions": { "modes": { "dark": "{primitive.acid.800}", "vibrant": "{primitive.acid.800}" } } },
    "secondary-foreground": { "$value": "{primitive.neutral.900}", "$extensions": { "modes": { "dark": "{primitive.neutral.950}", "vibrant": "{primitive.neutral.950}" } } },
    "muted": { "$value": "{primitive.neutral.100}", "$extensions": { "modes": { "dark": "{primitive.neutral.800}", "vibrant": "{primitive.magenta.900}" } } },
    "muted-foreground": { "$value": "{primitive.neutral.600}", "$extensions": { "modes": { "dark": "{primitive.neutral.300}", "vibrant": "{primitive.magenta.200}" } } },
    "accent": { "$value": "{primitive.magenta.100}", "$extensions": { "modes": { "dark": "{primitive.magenta.900}", "vibrant": "{primitive.magenta.800}" } } },
    "accent-foreground": { "$value": "{primitive.magenta.700}", "$extensions": { "modes": { "dark": "{primitive.magenta.300}", "vibrant": "{primitive.magenta.50}" } } },
    "destructive": { "$value": "{primitive.error.600}", "$extensions": { "modes": { "dark": "{primitive.error.600}", "vibrant": "{primitive.error.600}" } } },
    "destructive-hover": { "$value": "{primitive.error.700}", "$extensions": { "modes": { "dark": "{primitive.error.700}", "vibrant": "{primitive.error.700}" } } },
    "destructive-foreground": { "$value": "{primitive.error.50}" },
    "success": { "$value": "{primitive.success.700}", "$extensions": { "modes": { "dark": "{primitive.success.300}", "vibrant": "{primitive.success.200}" } } },
    "warning": { "$value": "{primitive.warning.700}", "$extensions": { "modes": { "dark": "{primitive.warning.300}", "vibrant": "{primitive.warning.200}" } } },
    "error": { "$value": "{primitive.error.600}", "$extensions": { "modes": { "dark": "{primitive.error.300}", "vibrant": "{primitive.error.200}" } } },
    "border": { "$value": "{primitive.neutral.200}", "$extensions": { "modes": { "dark": "{primitive.neutral.700}", "vibrant": "{primitive.magenta.800}" } } },
    "input": { "$value": "{primitive.neutral.200}", "$extensions": { "modes": { "dark": "{primitive.neutral.700}", "vibrant": "{primitive.magenta.700}" } } },
    "ring": { "$value": "{primitive.magenta.500}", "$extensions": { "modes": { "dark": "{primitive.acid.300}", "vibrant": "{primitive.acid.300}" } } },
    "chart-1": { "$value": "#DE3981", "$extensions": { "modes": { "dark": "#FF7FB1", "vibrant": "#FF7FB1" } } },
    "chart-2": { "$value": "#129000", "$extensions": { "modes": { "dark": "#50C32A", "vibrant": "#83FF62" } } },
    "chart-3": { "$value": "#795FFF", "$extensions": { "modes": { "dark": "#AAA2FF", "vibrant": "#AAA2FF" } } },
    "chart-4": { "$value": "#008794", "$extensions": { "modes": { "dark": "#00BCCF", "vibrant": "#00DCEB" } } },
    "chart-5": { "$value": "#BE6600", "$extensions": { "modes": { "dark": "#FC9200", "vibrant": "#FFAA00" } } },
    "sidebar": { "$value": "{semantic.background}" },
    "sidebar-foreground": { "$value": "{semantic.foreground}" },
    "sidebar-primary": { "$value": "{semantic.primary}" },
    "sidebar-primary-foreground": { "$value": "{semantic.primary-foreground}" },
    "sidebar-accent": { "$value": "{semantic.muted}" },
    "sidebar-accent-foreground": { "$value": "{semantic.foreground}" },
    "sidebar-border": { "$value": "{semantic.border}" },
    "sidebar-ring": { "$value": "{semantic.ring}" },
    "ai-agent-bg": { "$value": "{primitive.magenta.100}", "$extensions": { "modes": { "dark": "{primitive.magenta.900}", "vibrant": "{primitive.magenta.800}" } } },
    "ai-agent-fg": { "$value": "{primitive.magenta.700}", "$extensions": { "modes": { "dark": "{primitive.magenta.300}", "vibrant": "{primitive.magenta.50}" } } },
    "ai-thinking": { "$value": "{semantic.muted-foreground}" },
    "ai-tool-bg": { "$value": "{semantic.muted}" },
    "ai-stream-shimmer": { "$value": "{primitive.neutral.200}", "$extensions": { "modes": { "dark": "{primitive.neutral.700}", "vibrant": "{primitive.magenta.700}" } } },
    "ai-citation": { "$value": "{primitive.magenta.600}", "$extensions": { "modes": { "dark": "{primitive.magenta.300}", "vibrant": "{primitive.acid.200}" } } }
  },
  "component": {
    "button-primary-bg": { "$value": "{semantic.primary}" },
    "button-primary-bg-hover": { "$value": "{semantic.primary-hover}" },
    "button-primary-bg-disabled": { "$value": "{semantic.primary-disabled}" },
    "button-primary-fg": { "$value": "{semantic.primary-foreground}" },
    "button-secondary-bg": { "$value": "{semantic.secondary}" },
    "button-secondary-bg-hover": { "$value": "{semantic.secondary-hover}" },
    "button-secondary-fg": { "$value": "{semantic.secondary-foreground}" },
    "button-destructive-bg": { "$value": "{semantic.destructive}" },
    "button-destructive-bg-hover": { "$value": "{semantic.destructive-hover}" },
    "button-destructive-fg": { "$value": "{semantic.destructive-foreground}" },
    "button-outline": { "$value": "{semantic.primary}" },
    "button-radius": { "$value": "{foundation.radius.lg}" },
    "input-bg": { "$value": "{semantic.background}" },
    "input-border": { "$value": "{semantic.input}" },
    "input-border-focus": { "$value": "{semantic.ring}" },
    "input-border-error": { "$value": "{semantic.destructive}" },
    "input-placeholder": { "$value": "{semantic.muted-foreground}" },
    "agent-card-bg": { "$value": "{semantic.ai-agent-bg}" },
    "agent-card-fg": { "$value": "{semantic.ai-agent-fg}" },
    "agent-card-border": { "$value": "{semantic.border}" },
    "chat-bubble-user-bg": { "$value": "{semantic.primary}" },
    "chat-bubble-user-fg": { "$value": "{semantic.primary-foreground}" },
    "chat-bubble-assistant-bg": { "$value": "{semantic.card}" },
    "chat-bubble-assistant-fg": { "$value": "{semantic.card-foreground}" },
    "kpi-card-bg": { "$value": "{semantic.card}" },
    "insight-bg": { "$value": "{semantic.accent}" },
    "insight-fg": { "$value": "{semantic.accent-foreground}" }
  },
  "color": {
    "surface": {
      "default": {
        "$type": "color",
        "$value": "{semantic.background}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.neutral.900}"
          }
        }
      }
    },
    "action": {
      "primary-bg": {
        "$value": "{semantic.primary}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.magenta.500}"
          }
        }
      },
      "primary-hover-bg": { "$value": "{semantic.primary-hover}" },
      "secondary-bg": {
        "$value": "{semantic.secondary}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.acid.300}"
          }
        }
      },
      "secondary-hover-bg": { "$value": "{semantic.secondary-hover}" },
      "destructive-bg": { "$value": "{semantic.destructive}" },
      "destructive-hover-bg": { "$value": "{semantic.destructive-hover}" }
    },
    "text": {
      "default": {
        "$value": "{semantic.foreground}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.neutral.100}"
          },
          "apca": {
            "role": "body",
            "on": "color.surface.default"
          }
        }
      },
      "subtle": {
        "$value": "{semantic.muted-foreground}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.neutral.300}"
          },
          "apca": {
            "role": "ui",
            "on": "color.surface.default"
          }
        }
      },
      "link": {
        "$value": "{semantic.ai-citation}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.magenta.300}"
          },
          "apca": {
            "role": "ui",
            "on": "color.surface.default"
          }
        }
      },
      "on-primary": {
        "$value": "{semantic.primary-foreground}",
        "$extensions": {
          "modes": {
            "dark": "#FFFFFF"
          },
          "apca": {
            "role": "ui",
            "on": "color.action.primary-bg"
          }
        }
      },
      "on-primary-hover": {
        "$value": "{semantic.primary-foreground}",
        "$extensions": { "apca": { "role": "ui", "on": "color.action.primary-hover-bg" } }
      },
      "on-secondary": {
        "$value": "{semantic.secondary-foreground}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.neutral.950}"
          },
          "apca": {
            "role": "ui",
            "on": "color.action.secondary-bg"
          }
        }
      },
      "on-secondary-hover": {
        "$value": "{semantic.secondary-foreground}",
        "$extensions": { "apca": { "role": "ui", "on": "color.action.secondary-hover-bg" } }
      },
      "on-destructive": {
        "$value": "{semantic.destructive-foreground}",
        "$extensions": { "apca": { "role": "ui", "on": "color.action.destructive-bg" } }
      },
      "on-destructive-hover": {
        "$value": "{semantic.destructive-foreground}",
        "$extensions": { "apca": { "role": "ui", "on": "color.action.destructive-hover-bg" } }
      }
    },
    "feedback": {
      "success-text": {
        "$value": "{semantic.success}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.success.300}"
          },
          "apca": {
            "role": "ui",
            "on": "color.surface.default"
          }
        }
      },
      "warning-text": {
        "$value": "{semantic.warning}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.warning.300}"
          },
          "apca": {
            "role": "ui",
            "on": "color.surface.default"
          }
        }
      },
      "error-text": {
        "$value": "{semantic.error}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.error.300}"
          },
          "apca": {
            "role": "ui",
            "on": "color.surface.default"
          }
        }
      }
    },
    "dataviz": {
      "chart-1": { "$value": "{semantic.chart-1}", "$extensions": { "apca": { "role": "nontext", "on": "color.surface.default" } } },
      "chart-2": { "$value": "{semantic.chart-2}", "$extensions": { "apca": { "role": "nontext", "on": "color.surface.default" } } },
      "chart-3": { "$value": "{semantic.chart-3}", "$extensions": { "apca": { "role": "nontext", "on": "color.surface.default" } } },
      "chart-4": { "$value": "{semantic.chart-4}", "$extensions": { "apca": { "role": "nontext", "on": "color.surface.default" } } },
      "chart-5": { "$value": "{semantic.chart-5}", "$extensions": { "apca": { "role": "nontext", "on": "color.surface.default" } } }
    },
    "border": {
      "focus": {
        "$value": "{semantic.ring}",
        "$extensions": {
          "modes": {
            "dark": "{primitive.acid.300}"
          },
          "apca": {
            "role": "nontext",
            "on": "color.surface.default"
          }
        }
      }
    }
  }
}
