    "@storybook/web-components-vite": "^8.4.7",
    "eslint": "^9.16.0",
    "storybook": "^8.4.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "customElements": "dist/custom-elements.json"
