{
  "name": "@flytrap/docs",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:live": "tsc --noEmit && vite build --base=./",
    "build:pages": "tsc --noEmit && vite build --base=/flytrapds/",
    "live": "pnpm build:live && live-server ../.. --host=0.0.0.0 --port=5500 --entry-file=index.html",
    "live:dist": "pnpm build && live-server dist --host=0.0.0.0 --port=5500 --entry-file=index.html",
    "live:pages": "pnpm build:pages && live-server dist --host=0.0.0.0 --port=5500 --entry-file=index.html",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@flytrap/tokens": "workspace:*",
    "@flytrap/ui": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "gsap": "^3.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@flytrap/config": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "live-server": "^1.2.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.3.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
